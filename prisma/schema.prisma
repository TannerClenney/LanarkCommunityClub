// Lanark Community Club – Prisma Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / User ─────────────────────────────────────────────────────────────

enum Role {
  PENDING
  MEMBER
  SECRETARY
  TREASURER
  VICE_PRESIDENT
  PRESIDENT
  OFFICER
  ADMIN
}

enum TaskStatus {
  OPEN
  OWNED
  DONE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(PENDING)
  bio           String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  announcements Announcement[]
  threads       Thread[]
  posts         Post[]
  ownedTasks    Task[]         @relation("TaskOwner")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Public Content ───────────────────────────────────────────────────────────

model Event {
  id               String      @id @default(cuid())
  title            String
  slug             String      @unique
  description      String
  location         String?
  startDate        DateTime
  endDate          DateTime?
  isPublic         Boolean     @default(true)
  isFeatured       Boolean     @default(false)
  showInMemberHub  Boolean     @default(true)
  archived         Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  areas            EventArea[]
  tasks            Task[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("completed")
  year        Int?
  imageUrl    String?
  isFeatured  Boolean  @default(false)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Scholarship {
  id            String   @id @default(cuid())
  recipientName String
  year          Int
  amount        Float?
  description   String?
  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  caption   String?
  category  String?
  featured  Boolean  @default(false)
  archived  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomepageHighlight {
  id        String   @id @default(cuid())
  heading   String
  body      String
  linkText  String?
  linkHref  String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Members Area ─────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  isPinned  Boolean  @default(false)
  archived  Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])
}

model Thread {
  id        String   @id @default(cuid())
  title     String
  body      String
  authorId  String
  pinned    Boolean  @default(false)
  locked    Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User   @relation(fields: [authorId], references: [id])
  posts  Post[]
}

model Post {
  id        String   @id @default(cuid())
  body      String
  authorId  String
  threadId  String
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User   @relation(fields: [authorId], references: [id])
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model EventArea {
  id           String   @id @default(cuid())
  eventId      String
  name         String
  slug         String
  description  String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([eventId, slug])
  @@index([eventId, displayOrder])
}

model Task {
  id           String     @id @default(cuid())
  eventId      String
  eventAreaId  String
  title        String
  description  String?
  status       TaskStatus @default(OPEN)
  ownerId      String?
  displayOrder Int        @default(0)
  startTime    DateTime?
  endTime      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventArea EventArea @relation(fields: [eventAreaId], references: [id], onDelete: Cascade)
  owner     User?     @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@unique([eventAreaId, title])
  @@index([eventId, displayOrder])
  @@index([eventAreaId, displayOrder])
  @@index([ownerId])
}

// ─── Contact ──────────────────────────────────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
